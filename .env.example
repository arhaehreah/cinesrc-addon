# ── Server ────────────────────────────────────────────────────────────────────
PORT=7860

# ── TMDB API (required for IMDb-ID support) ───────────────────────────────────
# Get a free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# ── CineSrc player tweaks (all optional) ──────────────────────────────────────
# Auto-skip intro segments (true/false, default false)
CINESRC_AUTOSKIP=false

# Auto-play next episode when current one ends (true/false, default true)
CINESRC_AUTONEXT=true

# Preferred quality: "1080", "720", "480" — leave blank for player default
CINESRC_QUALITY=1080

# Player accent colour (hex without #)
CINESRC_COLOR=#e50914

# Seek-button duration in seconds (1-99, default 10)
CINESRC_SEEK=10
